# PostgreSQL（本機或 Neon；勿提交真實連線字串到 Git）
# 舊版 SQLite（file:./dev.db）已不再支援 — 若仍見 P1012，請改為 postgresql://
# 本機 Docker：docker compose up -d  →  DATABASE_URL 見下方
# Neon：https://neon.tech 建立專案後複製 Connection string（建議加 ?sslmode=require）
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/gov_procurement"
NEXTAUTH_URL="http://localhost:3000"
AUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="請改成隨機長字串"
# Google OAuth（專案 government-procurement-act2）詳見 GOOGLE-OAUTH.md、DEPLOY.md
# 本機重新導向 URI: http://localhost:3000/api/auth/callback/google
# 正式環境另加: https://你的網域.vercel.app/api/auth/callback/google
GOOGLE_CLIENT_ID="xxxx.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="GOCSPX-xxxx"
# Auth.js 也支援下列別名（二擇一即可）
# AUTH_GOOGLE_ID=
# AUTH_GOOGLE_SECRET=
# 逗號分隔信箱清單；列名者登入後為 ADMIN
ADMIN_EMAILS="khtsai1973@gmail.com"
# 選填：有設定時回答改由模型在摘錄範圍內生成
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o-mini"
OPENAI_EMBEDDING_MODEL="text-embedding-3-small"
# 設為 true 時永遠不用 OpenAI，僅回傳知識庫摘錄（額度用完時可設）
OPENAI_DISABLED="false"
# RAG 檢索（需 corpus:ingest + corpus:embed）
RAG_FETCH_K="40"
RAG_TOP_K="8"
RAG_MMR_LAMBDA="0.65"

# --- 部署備註（Vercel + Neon）---
# 1. 在 Neon 建立資料庫，將 DATABASE_URL 設到 Vercel → Settings → Environment Variables
# 2. Vercel 上 NEXTAUTH_URL / AUTH_URL 設為 https://你的網域.vercel.app
# 3. 首次部署後在本機對「正式 DATABASE_URL」執行：npm run db:push && npm run db:seed && npm run corpus:rag-init
# 詳細步驟見 DEPLOY.md
